# ============================================================
# La Vie En Rose 34 - Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Server
PORT=8787
NODE_ENV=development

# SQLite database path (optional - defaults to .data/store.sqlite)
# SQLITE_DB_PATH=/path/to/store.sqlite
# LVER_DATA_DIR=/path/to/data/directory

# JWT secret - REQUIRED in production (min 32 chars)
LVER_JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# Allow local JWT fallback when Firebase is unavailable
# Set to "true" in development for offline use
LVER_ALLOW_LOCAL_FALLBACK=true

# Firebase Admin SDK
# Either provide a JSON service account or use Application Default Credentials
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Default admin user (only used on first run if no users exist)
# LVER_ADMIN_USER=admin
# LVER_ADMIN_PASS_HASH=<bcrypt hash>

# Public base URL for QR codes in repair/reservation orders
LVER_PUBLIC_BASE_URL=http://localhost:5173

# Demo data seed (set to "1" to populate demo products on fresh DB)
# LVER_SEED_DEMO=1
